# ══════════════════════════════════════════════════════════════════════════════
# AltCarbon Grants Engine — Environment Variables
# Copy to .env and fill in values. Variables marked [REQUIRED] must be set.
# ══════════════════════════════════════════════════════════════════════════════

# ── Core [REQUIRED] ───────────────────────────────────────────────────────────
MONGODB_URI=your-mongodb-uri-here
INTERNAL_SECRET=your-internal-secret-here           # [REQUIRED] Change from default!
CRON_SECRET=your-cron-secret-here                   # [REQUIRED] Change from default!

# ── AI Models [REQUIRED — at least one of gateway or anthropic] ───────────────
AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1
AI_GATEWAY_API_KEY=your-gateway-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here       # Fallback if no gateway key
OPENAI_API_KEY=your-openai-api-key-here             # [Optional] Legacy — embeddings via Pinecone

# ── Search Tools [REQUIRED — at least Tavily] ────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key-here
EXA_API_KEY=your-exa-api-key-here                   # [Optional]
PERPLEXITY_API_KEY=your-perplexity-api-key-here     # [Optional]
JINA_API_KEY=your-jina-api-key-here                 # [Optional]

# ── Notion [REQUIRED for sync] ───────────────────────────────────────────────
NOTION_TOKEN=your-notion-token-here
NOTION_KNOWLEDGE_BASE_PAGE_ID=                      # [Optional] Scope sync to this page tree
NOTION_WEBHOOK_SECRET=                              # [Optional] HMAC signature validation

# Notion Data Source IDs (defaults are AltCarbon's — override for your workspace)
NOTION_MISSION_CONTROL_PAGE_ID=30b50d0e-c20e-8057-aee5-f775b9902c95
NOTION_GRANT_PIPELINE_DS=8e9cd5d9-0239-4072-8233-6006aa184e48
NOTION_AGENT_RUNS_DS=6848a08a-a5ab-4627-989b-22dac3195f42
NOTION_ERROR_LOGS_DS=2149b3a1-aa9c-456d-8daf-fce6858807be
NOTION_TRIAGE_DECISIONS_DS=3fc6834d-18b2-4e95-91dc-06ccca42b679
NOTION_DRAFT_SECTIONS_DS=c244df69-d74e-4703-ac88-d506c85aabe2
NOTION_KNOWLEDGE_CONNECTIONS_DS=1ce5cd69-d174-40bc-9c6a-8277e7a692a4
NOTION_DOCUMENTS_LIST_DS=30d50d0e-c20e-8062-bdb6-000b82620d34
NOTION_TABLE_OF_CONTENT_DS=31f50d0e-c20e-80d1-b22a-e7124bd9103e

# ── Vector DB [REQUIRED for knowledge retrieval] ─────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=grants-engine

# ── Frontend Auth [REQUIRED] ─────────────────────────────────────────────────
AUTH_SECRET=your-nextauth-secret-here               # generate with: openssl rand -base64 32
AUTH_TRUST_HOST=true
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ── Google Drive (backend integration) ───────────────────────────────────────
GOOGLE_REFRESH_TOKEN=your-google-refresh-token-here # [Optional] For Drive doc fetching

# ── Pusher (real-time comments) [REQUIRED for frontend] ──────────────────────
PUSHER_APP_ID=your-pusher-app-id-here
NEXT_PUBLIC_PUSHER_KEY=your-pusher-key-here
PUSHER_SECRET=your-pusher-secret-here
NEXT_PUBLIC_PUSHER_CLUSTER=your-pusher-cluster-here

# ── Cloudflare Browser Rendering [Optional] ──────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id-here
CLOUDFLARE_BROWSER_TOKEN=your-cloudflare-browser-token-here

# ── Slack (MCP integration) [Optional] ───────────────────────────────────────
SLACK_BOT_TOKEN=your-slack-bot-token-here
SLACK_TEAM_ID=your-slack-team-id-here

# ── Frontend URLs [REQUIRED] ─────────────────────────────────────────────────
FASTAPI_URL=http://localhost:8000
NOTION_WORKSPACE_URL=https://www.notion.so/your-workspace/

# ── LangSmith (tracing) [Optional] ───────────────────────────────────────────
LANGCHAIN_API_KEY=your-langchain-api-key-here
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=altcarbon-grants

# ── Agent Config [Optional — sensible defaults provided] ─────────────────────
SCOUT_FREQUENCY_HOURS=48
PURSUE_THRESHOLD=6.5
WATCH_THRESHOLD=5.0
MIN_GRANT_FUNDING=3000
SCORING_WEIGHTS=                                    # [Optional] JSON string, 6 keys summing to 1.0
SCORE_FLOOR=4.0
THEME_ALIGNMENT_FLOOR=2

# ── Company Config [Optional — defaults to AltCarbon] ────────────────────────
COMPANY_NAME=AltCarbon
COMPANY_DOMAIN=altcarbon.com

# ── Chunking Parameters [Optional] ───────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=80
MIN_CHUNK_WORDS=40

# ── Model Overrides [Optional — blank uses agent defaults] ───────────────────
SCOUT_MODEL=
ANALYST_HEAVY_MODEL=
DRAFTER_MODEL=

# ── Analyst Guardrails [Optional] ────────────────────────────────────────────
RED_FLAG_PENALTY=0.5                                # Per-red-flag score reduction
RED_FLAG_MAX_PENALTY=2.0                            # Maximum total red-flag penalty
MIN_FUNDING_INR=150000                              # INR minimum funding threshold (₹1.5L)
EXCHANGE_RATES=                                     # [Optional] JSON string of currency→rate, e.g. {"USD":1,"INR":83.5}

# ── Reviewer Guardrails [Optional] ───────────────────────────────────────────
REVIEWER_REVISION_THRESHOLD=6.0                     # Sections scoring below this get flagged
REVIEWER_EXPORT_THRESHOLD=6.5                       # Overall score needed for ready_for_export

# ── Drafter Guardrails [Optional] ────────────────────────────────────────────
DEFAULT_SECTION_WORD_LIMIT=500                      # Fallback word limit when section has none
MAX_REVISION_ATTEMPTS=3                             # Max auto-revision attempts per section

# ── Scout Guardrails [Optional] ──────────────────────────────────────────────
SCOUT_ENRICHMENT_TIMEOUT=45                         # Per-item enrichment timeout (seconds)
SCOUT_CRAWL_TIMEOUT=180                             # Overall direct-crawl phase timeout (seconds)
JINA_CONCURRENCY=3                                  # Max concurrent Jina Reader requests
JINA_DELAY=1.0                                      # Delay between Jina requests per slot (seconds)

# ── Railway (set automatically — do not override) ────────────────────────────
# PORT=8000
# RAILWAY_URL=

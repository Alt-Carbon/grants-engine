# ══════════════════════════════════════════════════════════════════════════════
# AltCarbon Grants Engine — Environment Variables
# Copy to .env and fill in values. Variables marked [REQUIRED] must be set.
# ══════════════════════════════════════════════════════════════════════════════

# ── Database [REQUIRED] ──────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/altcarbon_grants

# ── AI Gateway (routes all LLM calls) [REQUIRED — one of gateway or anthropic] ─
AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1
AI_GATEWAY_API_KEY=

# ── Anthropic (fallback if no gateway) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (legacy — embeddings handled by Pinecone) ────────────────────────
OPENAI_API_KEY=sk-...

# ── Notion [REQUIRED for sync] ──────────────────────────────────────────────
NOTION_TOKEN=secret_...
NOTION_KNOWLEDGE_BASE_PAGE_ID=
NOTION_WEBHOOK_SECRET=

# ── Google (Drive integration) ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Pinecone [REQUIRED for knowledge retrieval] ─────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=grants-engine

# ── Search Tools [REQUIRED — at least Tavily] ───────────────────────────────
TAVILY_API_KEY=tvly-...
EXA_API_KEY=
PERPLEXITY_API_KEY=pplx-...
JINA_API_KEY=

# ── Cloudflare Browser Rendering (optional) ─────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_BROWSER_TOKEN=

# ── Slack (optional — MCP integration) ──────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_TEAM_ID=

# ── Backend Auth [REQUIRED — change from defaults!] ─────────────────────────
CRON_SECRET=change-me-random-secret-32-chars
INTERNAL_SECRET=change-me-another-secret-32-chars

# ── CORS (comma-separated allowed origins) ──────────────────────────────────
CORS_ORIGINS=https://your-frontend.railway.app,http://localhost:3000

# ── Next.js Frontend [REQUIRED] ────────────────────────────────────────────
NEXTAUTH_URL=https://your-frontend.railway.app
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
GOOGLE_ID=                  # Google OAuth client ID
GOOGLE_SECRET=              # Google OAuth client secret
FASTAPI_URL=https://your-backend.railway.app

# ── Railway (set automatically by Railway) ──────────────────────────────────
# PORT=8000                 # Set by Railway, don't override
# RAILWAY_URL=              # Set by Railway

# ── LangSmith (optional — tracing) ─────────────────────────────────────────
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=altcarbon-grants

# ── Agent Defaults ──────────────────────────────────────────────────────────
SCOUT_FREQUENCY_HOURS=48
PURSUE_THRESHOLD=6.5
WATCH_THRESHOLD=5.0
MIN_GRANT_FUNDING=3000

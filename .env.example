# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/altcarbon_grants

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings only)
OPENAI_API_KEY=sk-...

# Knowledge sources
NOTION_TOKEN=secret_...
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...

# Search tools
TAVILY_API_KEY=tvly-...
EXA_API_KEY=...
PERPLEXITY_API_KEY=pplx-...
# Cloudflare Browser Rendering (page fetcher)
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_BROWSER_TOKEN=...

# Backend auth
CRON_SECRET=change-me-random-secret
INTERNAL_SECRET=change-me-another-secret

# Railway (set after deploy)
RAILWAY_URL=https://your-service.railway.app

# Next.js frontend (Vercel)
FASTAPI_URL=https://your-service.railway.app   # Railway FastAPI URL (same as RAILWAY_URL)

# LangSmith (optional)
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=altcarbon-grants
